generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  githubId    Int      @unique @map("github_id")
  username    String   @unique
  avatarUrl   String?  @map("avatar_url")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  wallpapers  Wallpaper[]
  votes       Vote[]
  collections Collection[]
  comments    Comment[]

  @@map("users")
}

model Wallpaper {
  id               String   @id @default(cuid())
  title            String?
  description      String?
  creatorId        String?  @map("creator_id")
  imageUrl         String   @map("image_url")
  generationParams Json     @map("generation_params")
  width            Int
  height           Int
  fileSize         Int?     @map("file_size")
  voteScore        Int      @default(0) @map("vote_score")
  voteCount        Int      @default(0) @map("vote_count")
  viewCount        Int      @default(0) @map("view_count")
  tags             String[]
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  creator          User?              @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  votes            Vote[]
  collectionItems  CollectionItem[]
  comments         Comment[]

  @@map("wallpapers")
}

model Vote {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  wallpaperId String   @map("wallpaper_id")
  voteType    Int      @map("vote_type") // -1 for downvote, 1 for upvote
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@unique([userId, wallpaperId])
  @@map("votes")
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  creatorId   String   @map("creator_id")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  creator User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  items   CollectionItem[]

  @@map("collections")
}

model CollectionItem {
  collectionId String   @map("collection_id")
  wallpaperId  String   @map("wallpaper_id")
  addedAt      DateTime @default(now()) @map("added_at")

  // Relations
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  wallpaper  Wallpaper  @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@id([collectionId, wallpaperId])
  @@map("collection_items")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorId    String   @map("author_id")
  wallpaperId String   @map("wallpaper_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@map("comments")
}